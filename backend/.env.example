# ===== Server =====
NODE_ENV=development
PORT=3000

# ===== Database (PostgreSQL) =====
DATABASE_URL=postgresql://viewer:viewer_pass@postgres:5432/viewer3d

# ===== JWT =====
JWT_SECRET=change-this-to-a-random-64char-string
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# ===== Storage =====
STORAGE_STRATEGY=local
UPLOAD_DIR=/app/uploads
MAX_FILE_SIZE=209715200

# ===== S3/MinIO (当 STORAGE_STRATEGY=s3 时启用) =====
S3_ENDPOINT=http://minio:9000
S3_BUCKET=viewer3d
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin

# ===== Share =====
SHARE_BASE_URL=http://localhost:8080/s

# ===== CORS =====
CORS_ORIGIN=http://localhost:8080
